# Шаблон ПРОД-окружения (webhook). Реальные значения вписать на сервере в /opt/telegram-bot/.env
# НЕ коммитить заполненный .env — он в .gitignore.

# === Telegram (webhook) ===
TELEGRAM_ENABLED=true
TELEGRAM_TRANSPORT=webhook
TELEGRAM_BOT_TOKEN=__PROD_TELEGRAM_BOT_TOKEN__
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_WEBHOOK_URL=https://bot.traektoria51.ru
TELEGRAM_WEBHOOK_HOST=127.0.0.1
TELEGRAM_WEBHOOK_PORT=3000
TELEGRAM_WEBHOOK_PATH=/telegram/webhook/__RANDOM_SECRET_PATH__
TELEGRAM_WEBHOOK_SECRET_TOKEN=__RANDOM_SECRET_TOKEN__
TELEGRAM_WEBHOOK_REGISTER=true

# === MAX (webhook) ===
MAX_ENABLED=true
MAX_BOT_TOKEN=__PROD_MAX_BOT_TOKEN__
MAX_API_BASE=https://platform-api.max.ru
MAX_WEBHOOK_URL=https://bot.traektoria51.ru
MAX_WEBHOOK_PATH=/max/webhook/__RANDOM_SECRET_PATH__
MAX_WEBHOOK_SECRET=__RANDOM_SECRET__
MAX_WEBHOOK_REGISTER=true
MAX_UPDATE_TYPES=message_created,message_callback,bot_started

# === Яндекс Алиса (webhook) ===
ALICE_ENABLED=true
ALICE_WEBHOOK_PATH=/alice/webhook/__RANDOM_SECRET_PATH__

# === web-chat ===
WEB_CHAT_ENABLED=true

# === Mattermost (по необходимости) ===
MATTERMOST_ENABLED=false
MATTERMOST_URL=https://mattermost.fabit.ru
MATTERMOST_TOKEN=__MATTERMOST_BOT_TOKEN__
MATTERMOST_MODE=mentions
MATTERMOST_REPLY_MODE=thread

# === LLM routing ===
LLM_ENABLED=true
LLM_PROVIDER=openrouter
LLM_DEFAULT_MODEL=openai/gpt-5.2
LLM_TIMEOUT_MS=20000
OPENROUTER_API_KEY=__PROD_OPENROUTER_API_KEY__
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_HTTP_REFERER=https://bot.traektoria51.ru
OPENROUTER_APP_TITLE=Traektoria51 Bot
OPENROUTER_PROXY_URL=

# Local provider: OpenAI-compatible endpoint on the server.
LOCAL_LLM_API_URL=http://127.0.0.1:8012/v1/chat/completions
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=qwen2.5-3b-instruct-q4_k_m
LOCAL_LLM_TIMEOUT_MS=20000

# Per-step model routing. Set provider to local for server-hosted models.
LLM_PROVIDER_DESCRIPTION_SELECTION=local
LLM_MODEL_DESCRIPTION_SELECTION=qwen2.5-3b-instruct-q4_k_m
LLM_PROVIDER_TRAJECTORY_DEEP=local
LLM_MODEL_TRAJECTORY_DEEP=qwen2.5-3b-instruct-q4_k_m
LLM_PROVIDER_PFDO_PARSER_EVALUATION=openrouter
LLM_MODEL_PFDO_PARSER_EVALUATION=openai/gpt-5.2
LLM_PROVIDER_PFDO_PARSER_REPAIR_PLAN=openrouter
LLM_MODEL_PFDO_PARSER_REPAIR_PLAN=openai/gpt-5.2

# === PostgreSQL (локальный на сервере) ===
DATABASE_URL=postgresql://localhost:5432/telegram_bot
PFDO_MIRROR_DATABASE_URL=postgresql://localhost:5432/pfdo_51_mirror
# На Linux psql обычно в PATH — укажите полный путь, если нужно: which psql
PSQL_BIN=psql

# === PFDO ===
PFDO_API_BASE=https://api.pfdo.ru/v2
PFDO_PORTAL_BASE=https://51.pfdo.ru
PFDO_OPERATOR_ID=37
PFDO_MAX_PAGES=3

# Legacy compatibility.
LOCAL_LLM_ENABLED=false
SCENARIO1_LLM_ONLY=false
